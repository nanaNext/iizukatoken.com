{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "types": ["node", "jest"]
  },
  "include": [
    "attendance/backend/src/**/*",
    "attendance/backend/tests/**/*",
    "playwright.config.ts"
  ]
}
